---
import Logo from "./Logo.astro";
import CanvasParticles from "./CanvasParticles.astro";
---

<section class="hero-section" id="hero">
  <CanvasParticles />
  <div class="hero-grid"></div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-stagger">
        <Logo variant="wordmark" class="hero-logo" />
      </div>
      <h1 class="hero-headline hero-stagger">Redirect load balancing,<br>simplified.</h1>
      <p class="hero-subtitle hero-stagger">
        Flux is a lightweight service registry and HTTP redirect balancer —
        no reverse proxy, no proxy overhead.
      </p>
      <div class="hero-ctas hero-stagger">
        <a href="/guides/quick-start/" class="cta-button cta-primary">Get Started</a>
        <a href="https://github.com/xinnaider/flux" class="cta-button cta-secondary" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
  <a href="#how-it-works" class="scroll-arrow" aria-label="Scroll to learn more">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <polyline points="19,12 12,19 5,12"/>
    </svg>
  </a>
</section>

<style>
.hero-section {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: var(--color-bg);
  overflow: hidden;
}
.hero-section .hero-inner {
  position: relative;
  z-index: 2;
}
.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image:
    linear-gradient(var(--color-text-primary) 1px, transparent 1px),
    linear-gradient(90deg, var(--color-text-primary) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-inner {
  max-width: 1120px;
  margin: 0 auto;
  padding: var(--space-6);
  width: 100%;
  position: relative;
  z-index: 1;
}
.hero-content {
  max-width: 680px;
}
.hero-logo {
  font-size: 28px;
  margin-bottom: var(--space-6);
}
.hero-headline {
  font-family: var(--font-heading);
  font-size: var(--text-5xl);
  line-height: var(--lh-tight);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-heading);
  margin: 0 0 var(--space-4);
}
.hero-subtitle {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  line-height: var(--lh-relaxed);
  color: var(--color-text-secondary);
  margin: 0 0 var(--space-8);
  max-width: 55ch;
}
.hero-ctas {
  display: flex;
  gap: var(--space-3);
  align-items: center;
}
.cta-primary {
  display: inline-block;
  background: var(--color-accent);
  color: #fff;
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-weight: var(--font-weight-bold);
  font-size: var(--text-base);
  text-decoration: none;
  line-height: 1;
}
.cta-primary:hover {
  background: var(--color-accent-hover);
}
.cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-sm);
  border: 1.5px solid var(--color-border);
  font-family: var(--font-body);
  font-weight: var(--font-weight-bold);
  font-size: var(--text-base);
  color: var(--color-text-primary);
  text-decoration: none;
  line-height: 1;
}
.cta-secondary:hover {
  border-color: var(--color-text-secondary);
}

/* Scroll down arrow */
.scroll-arrow {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  color: var(--color-text-secondary);
  animation: arrow-bounce 2s ease-in-out infinite;
  z-index: 2;
  transition: color var(--dur-fast) var(--ease-out);
}
.scroll-arrow:hover {
  color: var(--color-accent);
}

@keyframes arrow-bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.6; }
  50% { transform: translateX(-50%) translateY(8px); opacity: 1; }
}

@media (prefers-reduced-motion: reduce) {
  .scroll-arrow { animation: none; }
}

@media (max-width: 640px) {
  .hero-headline {
    font-size: var(--text-3xl);
    br { display: none; }
  }
  .hero-subtitle {
    font-size: var(--text-base);
  }
  .hero-ctas {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
