---
import Logo from "./Logo.astro";

const features = [
  {
    title: "Service Registry",
    desc: "Redis-backed, TTL-based health tracking. Services expire automatically — no heartbeats, no polling.",
  },
  {
    title: "Smart Balancer",
    desc: "Redirect mode (302) or reverse proxy mode. Least-connections selection. REST API, no config files.",
  },
  {
    title: "Simple API",
    desc: "RESTful, JSON over HTTP. Register, heartbeat, discover — everything you need.",
  },
];
---

<section class="how-section" id="how-it-works">
  <div class="how-inner">
    <div class="how-header">
      <h2 class="section-label">How It Works</h2>
      <p class="how-lead">Three operations. One registry. Zero configuration files.</p>
    </div>

    <!-- Features grid -->
    <div class="how-features">
      {features.map((f, i) => (
        <article class="how-card">
          <div class="how-card-icon">
            {i === 0 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="12" cy="12" r="3" fill="currentColor"/>
              </svg>
            )}
            {i === 1 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="8" cy="12" r="5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="8" cy="12" r="2" fill="currentColor"/>
                <line x1="13" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <polyline points="17,8 20,12 17,16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {i === 2 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M8 10l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M16 10l-3 3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="how-card-title">{f.title}</h3>
          <p class="how-card-desc">{f.desc}</p>
        </article>
      ))}
    </div>

    <!-- Architecture flow: both modes -->
    <div class="how-flow">
      <div class="flow-node">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M9 9l6 6M15 9l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Client</span>
      </div>

      <!-- Redirect path -->
      <div class="flow-arrow">
        <svg width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true" style="color:var(--color-accent)">
          <line x1="0" y1="8" x2="24" y2="8" stroke="currentColor" stroke-width="1.5"/>
          <polyline points="20,4 24,8 20,12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="flow-label">302</span>
      </div>

      <div class="flow-node flow-node-flux">
        <Logo variant="icon" size={28} />
        <span>flux</span>
      </div>

      <div class="flow-mode-switch">
        <span class="flow-modes">redirect</span>
        <span class="flow-modes divider">|</span>
        <span class="flow-modes active">proxy</span>
      </div>

      <!-- Proxy: flux → backends -->
      <div class="flow-fork">
        <div class="flow-arrow">
          <svg width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true" style="color:var(--color-text-secondary)">
            <line x1="0" y1="8" x2="24" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <polyline points="20,4 24,8 20,12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="flow-arrow">
          <svg width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true" style="color:var(--color-text-secondary)">
            <line x1="0" y1="8" x2="24" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <polyline points="20,4 24,8 20,12" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="flow-node">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Service A</span>
      </div>
      <div class="flow-node">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Service B</span>
      </div>
    </div>
  </div>
</section>

<style>
.how-section {
  display: flex;
  align-items: center;
}
.how-inner {
  max-width: 1120px;
  margin: 0 auto;
  padding: var(--space-6);
  width: 100%;
}
.how-header {
  margin-bottom: var(--space-10);
}
.how-lead {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: var(--color-text-secondary);
  margin: var(--space-2) 0 0;
}

/* Features */
.how-features {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
  margin-bottom: var(--space-12);
}
.how-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-6);
}
.how-card-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-3);
  color: var(--color-accent);
}
.how-card-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: var(--font-weight-heading);
  color: var(--color-text-primary);
  margin: 0 0 var(--space-2);
}
.how-card-desc {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: var(--lh-relaxed);
  color: var(--color-text-secondary);
  margin: 0;
}

/* Flow diagram */
.how-flow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  padding: var(--space-8);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}
.flow-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  font-family: var(--font-code);
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}
.flow-node svg { color: var(--color-text-secondary); }
.flow-node-flux svg { color: var(--color-accent); }
.flow-node-flux span { color: var(--color-accent); font-weight: var(--font-weight-bold); }
.flow-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.flow-label {
  font-family: var(--font-code);
  font-size: 9px;
  color: var(--color-accent);
}
.flow-mode-switch {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.flow-modes {
  font-family: var(--font-code);
  font-size: 9px;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.flow-modes.active {
  color: var(--color-accent);
  font-weight: var(--font-weight-bold);
}
.flow-modes.divider {
  opacity: 0.3;
}
.flow-fork {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

@media (max-width: 768px) {
  .how-features {
    grid-template-columns: 1fr;
  }
  .how-flow {
    flex-direction: column;
  }
  .flow-fork { flex-direction: row; }
}
</style>
