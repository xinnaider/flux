---
const features = [
  {
    title: "Service Registry",
    desc: "Redis-backed, TTL-based health tracking. No heartbeats, no polling — services expire automatically.",
    icon: "registry",
  },
  {
    title: "Redirect Balancer",
    desc: "HTTP 302 redirects with round-robin selection. No reverse proxy, no proxy overhead — the client goes direct.",
    icon: "balancer",
  },
  {
    title: "Simple API",
    desc: "RESTful, JSON over HTTP. Register, discover, list — three endpoints, everything you need.",
    icon: "api",
  },
];
---

<section class="features-section reveal" id="features">
  <div class="features-inner">
    <h2 class="section-label reveal reveal-delay-1">Why flux</h2>
    <div class="features-grid">
      {features.map((f, i) => (
        <article class="feature-card card-lift reveal" class:list={{ [`reveal-delay-${i + 1}`]: true }}>
          <div class="card-icon">
            {f.icon === "registry" && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" style="color:var(--color-accent)">
                <circle cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="14" cy="14" r="4" fill="currentColor"/>
              </svg>
            )}
            {f.icon === "balancer" && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                <g stroke="var(--color-text-primary)" stroke-width="1.5" fill="none">
                  <circle cx="10" cy="14" r="6"/>
                  <circle cx="10" cy="14" r="2.5" fill="var(--color-text-primary)"/>
                </g>
                <g stroke="var(--color-accent)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="16" y1="14" x2="24" y2="14"/>
                  <polyline points="21,10 24,14 21,18"/>
                </g>
              </svg>
            )}
            {f.icon === "api" && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" style="color:var(--color-gold)">
                <rect x="4" y="6" width="20" height="16" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M10 12l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18 12l-3 3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.features-section {
  padding: var(--space-24) 0;
  background: var(--color-bg);
}
.features-inner {
  max-width: 1120px;
  margin: 0 auto;
  padding: 0 var(--space-6);
}
.section-label {
  font-family: var(--font-code);
  font-size: var(--text-sm);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-accent);
  margin: 0 0 var(--space-8);
}
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.feature-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-8);
}
.card-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}
.feature-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: var(--font-weight-heading);
  color: var(--color-text-primary);
  margin: 0 0 var(--space-2);
}
.feature-desc {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: var(--lh-relaxed);
  color: var(--color-text-secondary);
  margin: 0;
}

@media (max-width: 768px) {
  .features-grid {
    grid-template-columns: 1fr;
  }
}
</style>
